BR2_arm=y
BR2_cortex_a7=y
BR2_ARM_FPU_NEON_VFPV4=y
BR2_ARM_INSTRUCTIONS_THUMB2=y
BR2_KERNEL_HEADERS_5_10=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y
BR2_OPTIMIZE_3=y
BR2_TARGET_GENERIC_HOSTNAME="luckfox pico"
BR2_TARGET_GENERIC_ISSUE="Welcome to luckfox pico"
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_EUDEV=y
BR2_TARGET_GENERIC_ROOT_PASSWD="luckfox"
BR2_SYSTEM_DEFAULT_PATH="/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin"
BR2_SYSTEM_ENABLE_NLS=y
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/board/luckfox/pico-86panel-w/post-image.sh"
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="5.10.160"
BR2_LINUX_KERNEL_DEFCONFIG="luckfox_rv1106_linux"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/../../luckfox-pico/sysdrv/source/kernel/arch/arm/configs/rv1106-bt.config $(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/../../luckfox-pico/sysdrv/source/kernel/arch/arm/configs/rv1106-gt911-module.config"
BR2_LINUX_KERNEL_IMAGE_TARGET_CUSTOM=y
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="zImage"
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="rv1106g-luckfox-pico-86panel-w"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"
BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG=y
# Source is provided via UBOOT_OVERRIDE_SRCDIR in local.mk (replaces the
# removed BR2_TARGET_UBOOT_CUSTOM_LOCAL). Version value is metadata only.
BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="2017.09"
BR2_TARGET_UBOOT_BOARD_DEFCONFIG="luckfox_rv1106_uboot"
BR2_TARGET_UBOOT_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/../../luckfox-pico/sysdrv/source/uboot/u-boot/configs/rk-emmc.config $(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/../../luckfox-pico/sysdrv/source/uboot/u-boot/configs/rv1106-luckfox-rgb-reset.config $(BR2_EXTERNAL_LUCKFOX_86PANEL_PATH)/board/luckfox/pico-86panel-w/uboot-adc-key.config"
BR2_TARGET_UBOOT_NEEDS_DTC=y
BR2_TARGET_UBOOT_INSTALL_IMAGES=y
BR2_PACKAGE_HOST_UBOOT_TOOLS=y
