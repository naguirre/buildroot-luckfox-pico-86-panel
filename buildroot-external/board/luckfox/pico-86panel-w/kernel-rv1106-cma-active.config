# The luckfox_rv1106_linux defconfig enables CONFIG_CMA_INACTIVE which is a
# Rockchip extension for fast-boot IPC (camera) targets.  When active, CMA
# skips zone validation and alloc_contig_range(), making dma_alloc_coherent()
# return unusable pages.  This breaks DRM/display (the 86Panel's 720×720 LCD
# framebuffer needs ~2 MB from CMA).
#
# Disable CMA_INACTIVE and set a sensible default CMA size for display use.
# CONFIG_CMA_INACTIVE is not set
CONFIG_CMA_SIZE_MBYTES=16
