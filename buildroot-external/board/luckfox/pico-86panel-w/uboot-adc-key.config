# The 86Panel W BOOT0 button is connected to SARADC_IN0 (GPIO4_C0_z, pin 26)
# with a pull-up on the motherboard. The stock BSP uses CONFIG_DM_KEY +
# CONFIG_ADC_KEY which reads the key via the adc-keys DT node with proper
# thresholds. Without CONFIG_DM_KEY, U-Boot falls into a raw CONFIG_ADC
# code path that misreads the floating pin as "download key pressed".
CONFIG_DM_KEY=y
CONFIG_ADC_KEY=y
