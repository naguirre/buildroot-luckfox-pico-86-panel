# WiFi stack and crypto modules required by AIC8800DC driver
# Produces: cfg80211.ko, libarc4.ko, ctr.ko, ccm.ko, libaes.ko, aes_generic.ko
CONFIG_WIRELESS=y
CONFIG_CFG80211=m
CONFIG_CFG80211_WEXT=y
CONFIG_CRYPTO_ARC4=m
CONFIG_CRYPTO_LIB_ARC4=m
CONFIG_CRYPTO_CTR=m
CONFIG_CRYPTO_CCM=m
CONFIG_CRYPTO_AES=m
CONFIG_CRYPTO_LIB_AES=m
